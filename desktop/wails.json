{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "ANT-Sub2API-Local",
  "outputfilename": "ANT-Sub2API-Local",
  "frontend:install": "cd ../frontend && pnpm install",
  "frontend:build": "cd ../frontend && pnpm run build",
  "frontend:dev:watcher": "cd ../frontend && pnpm run dev",
  "frontend:dev:serverUrl": "http://localhost:3000",
  "author": {
    "name": "ANT-Sub2API-Local"
  },
  "info": {
    "companyName": "ANT-Sub2API-Local",
    "productName": "ANT-Sub2API-Local",
    "productVersion": "1.0.0"
  },
  "wailsjsdir": "./frontend",
  "assetdir": "../backend/internal/web/dist",
  "reloaddirs": "../frontend/src,../backend/internal"
}
